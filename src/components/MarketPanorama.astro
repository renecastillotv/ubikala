---
/**
 * MarketPanorama.astro — Market intelligence section for Ubikala.
 * Dark "report" style design to differentiate from CLIC's light card layout.
 */

export interface Props {
  propertyType?: string | null;
  locationSlug?: string | null;
  operation?: string;
  countryCode?: string | null;
  language?: 'es' | 'en' | 'fr';
}

const {
  propertyType,
  locationSlug,
  operation = 'comprar',
  countryCode,
  language = 'es',
} = Astro.props;

// ─── Build the API path ─────────────────────────────────────────────────────

const COUNTRY_PREFIX: Record<string, string> = {
  'DO': '', 'MX': 'mx', 'CO': 'co', 'PA': 'pa', 'AR': 'ar', 'CR': 'cr',
};

const countryPrefix = countryCode ? (COUNTRY_PREFIX[countryCode.toUpperCase()] ?? '') : '';

let apiPath = countryPrefix ? `/${countryPrefix}` : '';
apiPath += `/${operation}`;
if (propertyType) apiPath += `/${propertyType}`;
if (locationSlug) apiPath += `/${locationSlug}`;

// ─── Fetch from API ──────────────────────────────────────────────────────────

interface Badge { label: string; value: string; raw?: number | null; }
interface Insight { type: string; title: string; body: string; href?: string; }
interface RelatedLink { label: string; href: string; }
interface PanoramaData {
  header: { title: string; subtitle?: string };
  badges: Badge[];
  insights: Insight[];
  narrative: string;
  related_links: RelatedLink[];
  source_note: string;
}

let panorama: PanoramaData | null = null;

const apiBase = import.meta.env.MARKET_PANORAMA_API_URL || '';

if (apiBase) {
  try {
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 5000);
    const url = `${apiBase}/api/market-panorama?path=${encodeURIComponent(apiPath)}&lang=${language}&brand=ubikala`;
    const res = await fetch(url, { signal: controller.signal });
    clearTimeout(timeout);
    if (res.ok) {
      panorama = await res.json() as PanoramaData;
    }
  } catch (_) {
    // Silently fail
  }
}

if (!panorama) return;

// ─── Dataset Schema JSON-LD ─────────────────────────────────────────────────

function badgeRaw(label: string): number | null {
  const b = panorama!.badges.find(b => b.label === label);
  return b?.raw ?? null;
}

const inventoryCount = badgeRaw('disponibles') ?? badgeRaw('en oferta') ?? 0;
const medianPrice = badgeRaw('precio mediano') ?? badgeRaw('precio referencia') ?? 0;
const pricePerM2 = badgeRaw('precio por m²') ?? badgeRaw('costo por m²') ?? 0;
const yieldEstimated = badgeRaw('yield estimado') ?? badgeRaw('rentabilidad anual') ?? null;

const datasetSchema = (inventoryCount > 0 || medianPrice > 0) ? {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: panorama.header.title,
  description: panorama.narrative?.substring(0, 300) || `Real estate market data: ${panorama.header.title}`,
  url: Astro.url.href,
  temporalCoverage: '2025/..',
  license: 'https://creativecommons.org/licenses/by/4.0/',
  creator: {
    '@type': 'Organization',
    name: 'Ubíkala',
    url: 'https://ubikala.com',
  },
  variableMeasured: [
    ...(medianPrice > 0 ? [{ '@type': 'PropertyValue', name: 'Median Price USD', value: medianPrice, unitCode: 'USD' }] : []),
    ...(pricePerM2 > 0 ? [{ '@type': 'PropertyValue', name: 'Price per m² USD', value: pricePerM2, unitCode: 'USD' }] : []),
    ...(inventoryCount > 0 ? [{ '@type': 'PropertyValue', name: 'Inventory Count', value: inventoryCount }] : []),
    ...(yieldEstimated ? [{ '@type': 'PropertyValue', name: 'Estimated Yield %', value: yieldEstimated }] : []),
  ],
} : null;

// ─── Insight accent colors (left border + icon) ─────────────────────────────

const INSIGHT_ACCENT: Record<string, { border: string; icon: string; bg: string }> = {
  premium_leader: { border: 'border-amber-400', icon: 'text-amber-400', bg: 'bg-amber-400/10' },
  value_entry:    { border: 'border-emerald-400', icon: 'text-emerald-400', bg: 'bg-emerald-400/10' },
  yield_leader:   { border: 'border-blue-400', icon: 'text-blue-400', bg: 'bg-blue-400/10' },
  yield_overview: { border: 'border-indigo-400', icon: 'text-indigo-400', bg: 'bg-indigo-400/10' },
  supply_leader:  { border: 'border-orange-400', icon: 'text-orange-400', bg: 'bg-orange-400/10' },
  market_breadth: { border: 'border-violet-400', icon: 'text-violet-400', bg: 'bg-violet-400/10' },
  vs_parent:      { border: 'border-cyan-400', icon: 'text-cyan-400', bg: 'bg-cyan-400/10' },
  price_positioning: { border: 'border-rose-400', icon: 'text-rose-400', bg: 'bg-rose-400/10' },
  supply_depth:   { border: 'border-teal-400', icon: 'text-teal-400', bg: 'bg-teal-400/10' },
};

const INSIGHT_SVG: Record<string, string> = {
  premium_leader: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
  value_entry: 'M7 7h10v2H7V7zm0 4h10v2H7v-2zm0 4h7v2H7v-2zM3 3h18a1 1 0 011 1v16a1 1 0 01-1 1H3a1 1 0 01-1-1V4a1 1 0 011-1z',
  yield_leader: 'M3 17l6-6 4 4 8-8M14 7h7v7',
  yield_overview: 'M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V4a2 2 0 00-2-2H6a2 2 0 00-2 2v14a2 2 0 002 2z',
  supply_leader: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2m-16 0H3m2-6h4m-4 4h4m6-8h4m-4 4h4',
  market_breadth: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  vs_parent: 'M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4',
  price_positioning: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  supply_depth: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
};

const defaultAccent = { border: 'border-gray-400', icon: 'text-gray-400', bg: 'bg-gray-400/10' };
---

<section class="py-14 bg-gray-900" data-market-panorama>
  <div class="max-w-5xl mx-auto px-4">

    {/* Header — light text on dark */}
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-1 h-8 bg-primary-500 rounded-full"></div>
        <span class="text-xs font-bold text-primary-400 uppercase tracking-[0.2em]">Panorama de Mercado</span>
      </div>
      <h2 class="text-2xl md:text-3xl font-bold text-white leading-tight">
        {panorama.header.title}
      </h2>
      {panorama.header.subtitle && (
        <p class="mt-2 text-gray-400 text-sm md:text-base">{panorama.header.subtitle}</p>
      )}
    </div>

    {/* Badges — horizontal strip with dividers */}
    {panorama.badges.length > 0 && (
      <div class="flex flex-wrap gap-0 mb-12 bg-gray-800/60 rounded-2xl border border-gray-700/50 overflow-hidden">
        {panorama.badges.map((badge, i) => (
          <div class={`flex-1 min-w-[140px] px-5 py-4 text-center ${i > 0 ? 'border-l border-gray-700/50' : ''}`}>
            <p class="text-[10px] font-semibold text-gray-500 uppercase tracking-[0.15em] mb-1">{badge.label}</p>
            <p class="text-xl md:text-2xl font-bold text-white leading-tight">{badge.value}</p>
          </div>
        ))}
      </div>
    )}

    {/* Insights — left-bordered cards, single column */}
    {panorama.insights.length > 0 && (
      <div class="space-y-3 mb-12">
        {panorama.insights.map((insight) => {
          const accent = INSIGHT_ACCENT[insight.type] || defaultAccent;
          const svgPath = INSIGHT_SVG[insight.type] || INSIGHT_SVG.yield_overview;
          return (
            <div class={`bg-gray-800/40 rounded-lg border-l-4 ${accent.border} p-5 hover:bg-gray-800/60 transition-colors`}>
              <div class="flex items-start gap-3">
                <div class={`flex-shrink-0 w-9 h-9 rounded-md flex items-center justify-center ${accent.bg}`}>
                  <svg class={`w-[18px] h-[18px] ${accent.icon}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d={svgPath} />
                  </svg>
                </div>
                <div class="min-w-0">
                  <h3 class="font-semibold text-white text-[15px] leading-snug mb-1">{insight.title}</h3>
                  <p class="text-sm text-gray-400 leading-relaxed">{insight.body}</p>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    )}

    {/* Narrative — highlighted quote block */}
    {panorama.narrative && (
      <div class="relative mb-10 pl-6 border-l-2 border-primary-500/40">
        <svg class="absolute -left-3 -top-1 w-6 h-6 text-primary-500/30" fill="currentColor" viewBox="0 0 24 24">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
        </svg>
        <p class="text-gray-300 text-sm md:text-base leading-relaxed italic">
          {panorama.narrative}
        </p>
      </div>
    )}

    {/* Related Links — underlined text links */}
    {panorama.related_links.length > 0 && (
      <div class="mb-8">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-[0.15em] mb-3">Explorar tambien</p>
        <nav class="flex flex-wrap gap-x-4 gap-y-2" aria-label="Related market searches">
          {panorama.related_links.map((link) => (
            <a
              href={link.href}
              class="text-sm text-primary-400 hover:text-primary-300 underline underline-offset-2 decoration-primary-400/30 hover:decoration-primary-300/50 transition-colors"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    )}

    {/* Source note */}
    <p class="text-[11px] text-gray-600 mt-6 border-t border-gray-800 pt-4">
      {panorama.source_note}
    </p>

  </div>
</section>

{datasetSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(datasetSchema)} />
)}
