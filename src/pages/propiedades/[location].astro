---
import Layout from '../../layouts/Layout.astro';
import SearchBox from '../../components/SearchBox.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { type Lang } from '../../i18n';
import { searchProperties, getSectorsWithCounts } from '../../lib/meilisearch';
import { getPageFAQs, getFAQSchema } from '../../lib/seo-content-db';
import SEOFAQSection from '../../components/SEOFAQSection.astro';
import { slugToName, slugToCityNames } from '../../lib/location-utils';
import { toSlug } from '../../lib/slug-utils';

// SSR for dynamic location pages
export const prerender = false;

const { location: locationSlug } = Astro.params;
const lang: Lang = 'es';

const pais = Astro.locals.country.name;

// Resolve the real city name from the slug via MeiliSearch facets
const resolvedName = await slugToName(locationSlug || '', pais);
const cityNames = await slugToCityNames(locationSlug || '', pais);
const cityFilter = cityNames.length > 1 ? cityNames : resolvedName;

// Fetch facet distribution: property types for sale and rent in this city
let ventaTipos: Array<{ name: string; slug: string; count: number; dbValue: string }> = [];
let rentaTipos: Array<{ name: string; slug: string; count: number; dbValue: string }> = [];
let totalCount = 0;

// Type display name mapping
const tipoDisplay: Record<string, { plural: string; slug: string; icon: string }> = {
  'apartamento': { plural: 'Apartamentos', slug: 'apartamento', icon: '🏢' },
  'casa': { plural: 'Casas', slug: 'casa', icon: '🏠' },
  'villa': { plural: 'Villas', slug: 'villa', icon: '🏡' },
  'penthouse': { plural: 'Penthouses', slug: 'penthouse', icon: '🌆' },
  'terreno': { plural: 'Terrenos', slug: 'terreno', icon: '🌳' },
  'solar': { plural: 'Solares', slug: 'solar', icon: '🌳' },
  'local comercial': { plural: 'Locales Comerciales', slug: 'local-comercial', icon: '🏪' },
  'oficina': { plural: 'Oficinas', slug: 'oficina', icon: '🏛️' },
  'nave': { plural: 'Naves Industriales', slug: 'nave', icon: '🏭' },
  'finca': { plural: 'Fincas', slug: 'finca', icon: '🌾' },
  'estudio': { plural: 'Estudios', slug: 'estudio', icon: '🛏️' },
};

function facetToTypes(distribution: Record<string, number>) {
  return Object.entries(distribution)
    .map(([dbType, count]) => {
      const info = tipoDisplay[dbType];
      if (!info) return null;
      return { name: info.plural, slug: info.slug, count: count as number, dbValue: dbType, icon: info.icon };
    })
    .filter(Boolean)
    .sort((a, b) => b!.count - a!.count) as Array<{ name: string; slug: string; count: number; dbValue: string; icon: string }>;
}

try {
  // Get sale types
  const ventaResult = await searchProperties({
    operacion: 'venta',
    ciudad: cityFilter,
    pais,
    limit: 0,
    facets: ['tipo'],
  });
  ventaTipos = facetToTypes(ventaResult.facetDistribution?.tipo || {});

  // Get rental types
  const rentaResult = await searchProperties({
    operacion: 'renta',
    ciudad: cityFilter,
    pais,
    limit: 0,
    facets: ['tipo'],
  });
  rentaTipos = facetToTypes(rentaResult.facetDistribution?.tipo || {});

  totalCount = (ventaResult.total || 0) + (rentaResult.total || 0);
} catch (error) {
  console.error('Error fetching location hub data:', error);
}

const ventaTotal = ventaTipos.reduce((sum, t) => sum + t.count, 0);
const rentaTotal = rentaTipos.reduce((sum, t) => sum + t.count, 0);

const pageTitle = `Propiedades en ${resolvedName}, ${pais} | Ubikala`;
const pageDescription = `Encuentra propiedades en ${resolvedName}: ${ventaTotal} en venta y ${rentaTotal} en alquiler. Apartamentos, casas, villas y mas en Ubikala.com`;

// DB-driven FAQs for this location
const country = Astro.locals.country;
const slugLower = (locationSlug || '').toLowerCase();
const faqs = await getPageFAQs(country.code, 'es', `location:${slugLower}`, pais);

// Get popular sectors in this city
let popularSectors: Array<{ name: string; slug: string; count: number }> = [];
try {
  popularSectors = await getSectorsWithCounts(cityFilter, pais);
  popularSectors = popularSectors.slice(0, 16);
} catch { /* ignore */ }

// Get other popular cities for internal linking
let otherCities: Array<{ name: string; slug: string; count: number }> = [];
try {
  const allResult = await searchProperties({
    pais,
    limit: 0,
    facets: ['ciudad'],
  });
  const distribution = allResult.facetDistribution?.ciudad || {};
  otherCities = Object.entries(distribution)
    .map(([name, count]) => ({ name, slug: toSlug(name), count: count as number }))
    .filter(c => c.slug !== locationSlug)
    .sort((a, b) => b.count - a.count)
    .slice(0, 8);
} catch { /* ignore */ }
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={`propiedades ${resolvedName}, inmuebles ${resolvedName}, comprar ${resolvedName}, alquilar ${resolvedName}`}
>
  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Propiedades', href: '/propiedades' },
    { label: resolvedName }
  ]} />

  <!-- Hero -->
  <section class="bg-gradient-to-r from-primary-600 to-primary-700 py-14">
    <div class="container-custom">
      <h1 class="text-3xl md:text-5xl font-bold text-white mb-4">
        Propiedades en {resolvedName}
      </h1>
      <p class="text-primary-100 text-lg max-w-2xl mb-6">
        {totalCount} propiedades disponibles en {resolvedName}, {pais}.
        Explora por tipo de propiedad y operacion.
      </p>
      <div class="flex gap-4">
        {ventaTotal > 0 && (
          <span class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm text-white px-4 py-2 rounded-full text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            {ventaTotal} en venta
          </span>
        )}
        {rentaTotal > 0 && (
          <span class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm text-white px-4 py-2 rounded-full text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {rentaTotal} en alquiler
          </span>
        )}
      </div>
    </div>
  </section>

  <!-- Search -->
  <section class="py-4 bg-white shadow-sm">
    <div class="container-custom">
      <SearchBox variant="compact" />
    </div>
  </section>

  <!-- Comprar section -->
  {ventaTipos.length > 0 && (
    <section class="py-12">
      <div class="container-custom">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-900">Comprar en {resolvedName}</h2>
            <p class="text-gray-500 text-sm">{ventaTotal} propiedades en venta</p>
          </div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {ventaTipos.map((tipo) => (
            <a
              href={`/comprar/${tipo.slug}/${locationSlug}`}
              class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 hover:shadow-md hover:border-primary-200 transition-all group"
            >
              <span class="text-2xl block mb-2">{(tipo as any).icon}</span>
              <span class="font-semibold text-gray-900 group-hover:text-primary-600 block">
                {tipo.name}
              </span>
              <span class="text-sm text-gray-500">{tipo.count} en venta</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Alquilar section -->
  {rentaTipos.length > 0 && (
    <section class="py-12 bg-gray-50">
      <div class="container-custom">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 bg-secondary-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-900">Alquilar en {resolvedName}</h2>
            <p class="text-gray-500 text-sm">{rentaTotal} propiedades en alquiler</p>
          </div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {rentaTipos.map((tipo) => (
            <a
              href={`/alquilar/${tipo.slug}/${locationSlug}`}
              class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 hover:shadow-md hover:border-secondary-200 transition-all group"
            >
              <span class="text-2xl block mb-2">{(tipo as any).icon}</span>
              <span class="font-semibold text-gray-900 group-hover:text-secondary-600 block">
                {tipo.name}
              </span>
              <span class="text-sm text-gray-500">{tipo.count} en alquiler</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Popular Sectors -->
  {popularSectors.length > 0 && (
    <section class="py-12">
      <div class="container-custom">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-900">Sectores en {resolvedName}</h2>
            <p class="text-gray-500 text-sm">Explora propiedades por sector</p>
          </div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {popularSectors.map((sector) => (
            <a
              href={`/comprar/${locationSlug}/${sector.slug}`}
              class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 hover:shadow-md hover:border-amber-200 transition-all group"
            >
              <span class="font-semibold text-gray-900 group-hover:text-amber-600 block">
                {sector.name}
              </span>
              <span class="text-sm text-gray-500">{sector.count} propiedades</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ Section - DB driven -->
  {faqs.length > 0 && <SEOFAQSection faqs={faqs} title={`Preguntas Frecuentes sobre ${resolvedName}`} />}
  {faqs.length > 0 && <script type="application/ld+json" set:html={JSON.stringify(getFAQSchema(faqs))} />}

  <!-- Other cities -->
  {otherCities.length > 0 && (
    <section class="py-12 bg-gray-50">
      <div class="container-custom">
        <h2 class="text-xl font-semibold text-gray-900 mb-6 text-center">Explora Otras Ubicaciones</h2>
        <div class="flex flex-wrap justify-center gap-3">
          {otherCities.map((city) => (
            <a
              href={`/propiedades/${city.slug}`}
              class="px-4 py-2 bg-white rounded-full text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 transition-colors shadow-sm"
            >
              {city.name} ({city.count})
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
