---
import Layout from '../../../../layouts/Layout.astro';
import PropertyCard from '../../../../components/PropertyCard.astro';
import SearchBox from '../../../../components/SearchBox.astro';
import Pagination from '../../../../components/Pagination.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import MarketPanorama from '../../../../components/MarketPanorama.astro';
import { searchProperties, getSectorsWithCounts } from '../../../../lib/meilisearch';
import type { Property } from '../../../../data/types';
import { slugToName, slugToCityNames, sectorSlugToName } from '../../../../lib/location-utils';
import { toSlug } from '../../../../lib/slug-utils';

export const prerender = false;

const { type: typeSlug, location: locationSlug, sector: sectorSlug } = Astro.params;

// Property type mapping (dynamic, no hardcoded countries)
const propertyTypeMap: Record<string, { dbValue: string; singular: string; plural: string; icon: string }> = {
  'apartamento': { dbValue: 'apartamento', singular: 'Apartamento', plural: 'Apartamentos', icon: '🏢' },
  'apartamentos': { dbValue: 'apartamento', singular: 'Apartamento', plural: 'Apartamentos', icon: '🏢' },
  'casa': { dbValue: 'casa', singular: 'Casa', plural: 'Casas', icon: '🏠' },
  'casas': { dbValue: 'casa', singular: 'Casa', plural: 'Casas', icon: '🏠' },
  'villa': { dbValue: 'villa', singular: 'Villa', plural: 'Villas', icon: '🏡' },
  'villas': { dbValue: 'villa', singular: 'Villa', plural: 'Villas', icon: '🏡' },
  'penthouse': { dbValue: 'penthouse', singular: 'Penthouse', plural: 'Penthouses', icon: '🌆' },
  'penthouses': { dbValue: 'penthouse', singular: 'Penthouse', plural: 'Penthouses', icon: '🌆' },
  'terreno': { dbValue: 'terreno', singular: 'Terreno', plural: 'Terrenos', icon: '🌳' },
  'terrenos': { dbValue: 'terreno', singular: 'Terreno', plural: 'Terrenos', icon: '🌳' },
  'solar': { dbValue: 'terreno', singular: 'Solar', plural: 'Solares', icon: '🌳' },
  'solares': { dbValue: 'terreno', singular: 'Solar', plural: 'Solares', icon: '🌳' },
  'local': { dbValue: 'local comercial', singular: 'Local Comercial', plural: 'Locales Comerciales', icon: '🏪' },
  'local-comercial': { dbValue: 'local comercial', singular: 'Local Comercial', plural: 'Locales Comerciales', icon: '🏪' },
  'locales': { dbValue: 'local comercial', singular: 'Local Comercial', plural: 'Locales Comerciales', icon: '🏪' },
  'oficina': { dbValue: 'oficina', singular: 'Oficina', plural: 'Oficinas', icon: '🏛️' },
  'oficinas': { dbValue: 'oficina', singular: 'Oficina', plural: 'Oficinas', icon: '🏛️' },
  'nave': { dbValue: 'nave', singular: 'Nave Industrial', plural: 'Naves Industriales', icon: '🏭' },
  'naves': { dbValue: 'nave', singular: 'Nave Industrial', plural: 'Naves Industriales', icon: '🏭' },
  'finca': { dbValue: 'finca', singular: 'Finca', plural: 'Fincas', icon: '🌾' },
  'fincas': { dbValue: 'finca', singular: 'Finca', plural: 'Fincas', icon: '🌾' },
};

const typeInfo = propertyTypeMap[typeSlug?.toLowerCase() || ''];
if (!typeInfo) {
  return Astro.redirect('/comprar');
}

const ITEMS_PER_PAGE = 24;
const currentPage = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1'));

// Read advanced filter query params
const precioParam = Astro.url.searchParams.get('precio');
const habitacionesParam = Astro.url.searchParams.get('habitaciones');
const banosParam = Astro.url.searchParams.get('banos');

let precioMin: number | undefined;
let precioMax: number | undefined;
if (precioParam) {
  if (precioParam.endsWith('+')) {
    precioMin = parseInt(precioParam);
  } else if (precioParam.includes('-')) {
    const [min, max] = precioParam.split('-').map(Number);
    precioMin = min || undefined;
    precioMax = max || undefined;
  }
}

const pais = Astro.locals.country?.name;

// Resolve city from slug
const resolvedCityName = await slugToName(locationSlug || '', pais);
const cityNames = await slugToCityNames(locationSlug || '', pais);

// Resolve sector from slug (within city context)
const resolvedSectorName = await sectorSlugToName(sectorSlug || '', cityNames, pais);

let locationData = {
  city: resolvedCityName,
  sector: resolvedSectorName,
  province: pais || '',
};

// Search with type + city + sector filters
let properties: Property[] = [];
let totalCount = 0;

try {
  const offset = (currentPage - 1) * ITEMS_PER_PAGE;

  const result = await searchProperties({
    operacion: 'venta',
    tipo: typeInfo.dbValue,
    ciudad: cityNames.length > 1 ? cityNames : resolvedCityName,
    sector: resolvedSectorName,
    precioMin,
    precioMax,
    habitacionesMin: habitacionesParam ? parseInt(habitacionesParam) : undefined,
    banosMin: banosParam ? parseInt(banosParam) : undefined,
    limit: ITEMS_PER_PAGE,
    offset,
    pais,
  });

  properties = result.properties;
  totalCount = result.total;

  if (properties.length > 0) {
    const firstProp = properties[0];
    if (firstProp.location.city) locationData.city = firstProp.location.city;
    if (firstProp.location.province) locationData.province = firstProp.location.province;
    if (firstProp.location.sector) locationData.sector = firstProp.location.sector;
  }
} catch (error) {
  console.error('Error fetching properties:', error);
}

const totalPages = Math.ceil(totalCount / ITEMS_PER_PAGE);

if (currentPage > totalPages && totalPages > 0) {
  return Astro.redirect(`/comprar/${typeSlug}/${locationSlug}/${sectorSlug}`);
}

// SEO
const pageTitle = `${typeInfo.plural} en Venta en ${locationData.sector}, ${locationData.city} | Ubikala`;
const pageDescription = `Encuentra ${typeInfo.plural.toLowerCase()} en venta en ${locationData.sector}, ${locationData.city}. ${totalCount} propiedades disponibles con fotos, precios y contacto directo.`;

// FAQs
const dynamicFAQs = [
  {
    question: `¿Cuanto cuesta un ${typeInfo.singular.toLowerCase()} en ${locationData.sector}?`,
    answer: `Los precios de ${typeInfo.plural.toLowerCase()} en ${locationData.sector}, ${locationData.city} varian segun el tamano, piso y amenidades. Actualmente tenemos ${totalCount} opciones disponibles. Explora el listado y contacta a los asesores para precios actualizados.`
  },
  {
    question: `¿Es buena zona ${locationData.sector} para comprar?`,
    answer: `${locationData.sector} es un sector de ${locationData.city} con demanda de ${typeInfo.plural.toLowerCase()}. Factores clave incluyen la plusvalia historica, servicios cercanos, transporte y seguridad. Un asesor inmobiliario local puede darte informacion especifica del mercado en ${locationData.sector}.`
  },
  {
    question: `¿Que servicios hay cerca de ${locationData.sector}?`,
    answer: `${locationData.sector} cuenta con acceso a servicios como supermercados, centros comerciales, escuelas, hospitales y transporte publico. La disponibilidad exacta varia, te recomendamos consultar con un asesor para conocer los detalles del area.`
  },
  {
    question: `¿Puedo financiar un ${typeInfo.singular.toLowerCase()} en ${locationData.sector}?`,
    answer: `Si, la mayoria de los ${typeInfo.plural.toLowerCase()} en ${locationData.sector} pueden financiarse a traves de bancos locales. Las tasas y plazos varian segun el banco y el proyecto. Algunos desarrolladores ofrecen financiamiento directo con condiciones flexibles.`
  },
];

// Schema
const listingSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${typeInfo.plural} en Venta en ${locationData.sector}, ${locationData.city}`,
  description: pageDescription,
  numberOfItems: totalCount,
  itemListElement: properties.slice(0, 10).map((property, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'RealEstateListing',
      name: property.title,
      description: property.description?.substring(0, 160),
      url: `https://ubikala.com/propiedad/${property.slug}`,
      image: property.images[0]?.url,
      offers: {
        '@type': 'Offer',
        price: property.price,
        priceCurrency: property.currency,
      },
    },
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: dynamicFAQs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

// Related sectors in same city for internal linking
let relatedSectors: Array<{ name: string; slug: string; count: number }> = [];
try {
  const allSectors = await getSectorsWithCounts(cityNames.length > 1 ? cityNames : resolvedCityName, pais);
  relatedSectors = allSectors
    .filter(s => toSlug(s.name) !== sectorSlug)
    .slice(0, 8);
} catch { /* ignore */ }

// Related types for same sector
const relatedTypes = Object.entries(propertyTypeMap)
  .filter(([slug, info]) => info.dbValue !== typeInfo.dbValue && !slug.endsWith('s') && slug !== 'solar' && slug !== 'local')
  .slice(0, 4)
  .map(([slug, info]) => ({ slug, ...info }));
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={`${typeInfo.plural.toLowerCase()} ${locationData.sector.toLowerCase()}, comprar ${typeInfo.singular.toLowerCase()} ${locationData.sector.toLowerCase()} ${locationData.city.toLowerCase()}, ${typeInfo.plural.toLowerCase()} venta ${locationData.sector.toLowerCase()}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(listingSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />

  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Comprar', href: '/comprar' },
    { label: typeInfo.plural, href: `/comprar/${typeSlug}` },
    { label: locationData.city, href: `/comprar/${typeSlug}/${locationSlug}` },
    { label: locationData.sector },
  ]} />

  <!-- Hero -->
  <section class="bg-gradient-to-r from-primary-600 to-primary-700 py-12">
    <div class="container-custom">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
        {typeInfo.plural} en Venta en {locationData.sector}
      </h1>
      <p class="text-primary-100 text-lg max-w-3xl">
        {totalCount > 0
          ? `Explora ${totalCount} ${typeInfo.plural.toLowerCase()} disponibles en ${locationData.sector}, ${locationData.city}.`
          : `Actualmente no hay ${typeInfo.plural.toLowerCase()} disponibles en ${locationData.sector}. Explora otros sectores o tipos de propiedad.`
        }
      </p>
    </div>
  </section>

  <!-- Search (collapsible) -->
  <section class="py-4 bg-gray-50 border-b">
    <div class="container-custom">
      <details>
        <summary class="cursor-pointer text-sm font-medium text-primary-600 hover:text-primary-700 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
          </svg>
          Modificar Busqueda
        </summary>
        <div class="mt-4">
          <SearchBox />
        </div>
      </details>
    </div>
  </section>

  <!-- Results or Empty State -->
  <section class="section">
    <div class="container-custom">
      {properties.length > 0 ? (
        <>
          <div class="flex items-center justify-between mb-8">
            <p class="text-gray-600">
              <span class="font-semibold text-gray-900">{totalCount}</span> {typeInfo.plural.toLowerCase()} en venta en {locationData.sector}
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {properties.map((property) => (
              <PropertyCard property={property} />
            ))}
          </div>

          {totalPages > 1 && (
            <div class="mt-12">
              <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl={`/comprar/${typeSlug}/${locationSlug}/${sectorSlug}`} />
            </div>
          )}
        </>
      ) : (
        <div class="text-center py-16">
          <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">
            No encontramos {typeInfo.plural.toLowerCase()} en {locationData.sector}
          </h2>
          <p class="text-gray-600 mb-8 max-w-md mx-auto">
            Prueba con otro sector o explora todas las propiedades en {locationData.city}.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/comprar/${typeSlug}/${locationSlug}`} class="btn-primary">
              Ver en {locationData.city}
            </a>
            <a href="/comprar" class="btn-outline">
              Ver Todas las Propiedades
            </a>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Market Panorama SEO Section -->
  <MarketPanorama
    propertyType={typeSlug}
    locationSlug={`${locationSlug}/${sectorSlug}`}
    operation="comprar"
    countryCode={Astro.locals.country?.code}
    language="es"
  />

  <!-- FAQs -->
  <section class="py-16">
    <div class="container-custom">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 text-center mb-4">
        Preguntas Frecuentes
      </h2>
      <p class="text-gray-600 text-center max-w-2xl mx-auto mb-12">
        Resolvemos tus dudas sobre comprar {typeInfo.plural.toLowerCase()} en {locationData.sector}
      </p>

      <div class="max-w-3xl mx-auto space-y-4">
        {dynamicFAQs.map((faq) => (
          <details class="bg-white rounded-xl shadow-sm group">
            <summary class="flex items-center justify-between p-6 cursor-pointer">
              <span class="font-semibold text-gray-900 pr-4">{faq.question}</span>
              <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Other sectors in same city (internal links for SEO) -->
  {relatedSectors.length > 0 && (
    <section class="py-16 bg-gray-50">
      <div class="container-custom">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">
          Otros Sectores en {locationData.city}
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {relatedSectors.map((s) => (
            <a
              href={`/comprar/${typeSlug}/${locationSlug}/${s.slug}`}
              class="bg-white rounded-xl p-4 shadow-sm hover:shadow-md transition-shadow group"
            >
              <span class="font-semibold text-gray-900 group-hover:text-primary-600 block">
                {s.name}
              </span>
              <span class="text-sm text-gray-500">{s.count} {typeInfo.plural.toLowerCase()}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Other property types in same sector -->
  <section class="py-16 {relatedSectors.length > 0 ? '' : 'bg-gray-50'}">
    <div class="container-custom">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">
        Otros Tipos de Propiedad en {locationData.sector}
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {relatedTypes.map((type) => (
          <a
            href={`/comprar/${type.slug}/${locationSlug}/${sectorSlug}`}
            class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow text-center group"
          >
            <span class="text-3xl block mb-2">{type.icon}</span>
            <span class="font-semibold text-gray-900 group-hover:text-primary-600">
              {type.plural}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-primary-600 to-primary-700">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-white mb-4">
          ¿Necesitas ayuda para encontrar tu {typeInfo.singular.toLowerCase()} en {locationData.sector}?
        </h2>
        <p class="text-primary-100 text-lg mb-8">
          Nuestros asesores conocen {locationData.sector} y pueden ayudarte a encontrar la propiedad ideal.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/asesores" class="bg-white text-primary-600 hover:bg-primary-50 font-semibold px-8 py-3 rounded-lg transition-colors">
            Contactar un Asesor
          </a>
          <a href={`/comprar/${typeSlug}/${locationSlug}`} class="border-2 border-white text-white hover:bg-white/10 font-semibold px-8 py-3 rounded-lg transition-colors">
            Ver Todo en {locationData.city}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Links -->
  <section class="py-12">
    <div class="container-custom">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Enlaces Relacionados</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href={`/comprar/${typeSlug}/${locationSlug}`} class="flex items-center gap-3 p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors group">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            </svg>
          </div>
          <div>
            <span class="font-semibold text-gray-900 group-hover:text-primary-600">{typeInfo.plural} en {locationData.city}</span>
            <p class="text-sm text-gray-500">Toda la ciudad</p>
          </div>
        </a>

        <a href={`/propiedades/${locationSlug}`} class="flex items-center gap-3 p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors group">
          <div class="w-10 h-10 bg-secondary-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <div>
            <span class="font-semibold text-gray-900 group-hover:text-primary-600">Todo en {locationData.city}</span>
            <p class="text-sm text-gray-500">Todas las propiedades</p>
          </div>
        </a>

        <a href="/comprar" class="flex items-center gap-3 p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors group">
          <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <div>
            <span class="font-semibold text-gray-900 group-hover:text-primary-600">Todas las Propiedades</span>
            <p class="text-sm text-gray-500">Buscar en todo el pais</p>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>
