---
import Layout from '../../layouts/Layout.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import SearchBox from '../../components/SearchBox.astro';
import Pagination from '../../components/Pagination.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { useTranslations, tPais, getAlternateUrls } from '../../i18n';
import { searchProperties, getMarketStats, getCitiesWithCounts } from '../../lib/meilisearch';
import { toSlug } from '../../lib/slug-utils';
import MarketStatsBar from '../../components/MarketStatsBar.astro';
import type { Property } from '../../data/types';
import { getPageFAQs, getPopularZones, getPropertyTypes, getInfoBox, getEducationalCards, getGuideHeader, getCTAContent, getFAQSchema } from '../../lib/seo-content-db';
import SEOPopularZones from '../../components/SEOPopularZones.astro';
import SEOPropertyTypes from '../../components/SEOPropertyTypes.astro';
import SEOInfoBox from '../../components/SEOInfoBox.astro';
import SEOEducationalCards from '../../components/SEOEducationalCards.astro';
import SEOFAQSection from '../../components/SEOFAQSection.astro';

// SSR para paginación
export const prerender = false;

const t = useTranslations('es');
const alternateUrls = getAlternateUrls('/comprar');
const country = Astro.locals.country;
const pais = country.name;

// Configuración de paginación
const ITEMS_PER_PAGE = 24;
const currentPage = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1'));

// Fetch properties from MeiliSearch with pagination
let properties: Property[] = [];
let totalCount = 0;
try {
  const offset = (currentPage - 1) * ITEMS_PER_PAGE;
  const result = await searchProperties({ operacion: 'venta', limit: ITEMS_PER_PAGE, offset, pais });
  properties = result.properties;
  totalCount = result.total;
} catch (error) {
  console.error('Error fetching properties:', error);
}

const totalPages = Math.ceil(totalCount / ITEMS_PER_PAGE);

let marketStats = null;
try { marketStats = await getMarketStats(pais); } catch {}

const searchLocations = await getCitiesWithCounts(pais);

// Fetch real type+city combinations with inventory for SEO links
const seoLinkTypes = ['apartamento', 'casa', 'terreno', 'villa'] as const;
const seoLinkLabels: Record<string, string> = {
  apartamento: 'Apartamentos', casa: 'Casas', terreno: 'Terrenos', villa: 'Villas',
};
type SeoLink = { label: string; href: string };
let verifiedSeoLinks: SeoLink[] = [];
try {
  const results = await Promise.all(
    seoLinkTypes.map(tipo =>
      searchProperties({ tipo, operacion: 'venta', pais, limit: 0, facets: ['ciudad'] })
    )
  );
  for (let i = 0; i < seoLinkTypes.length; i++) {
    const tipo = seoLinkTypes[i];
    const dist = results[i].facetDistribution?.ciudad || {};
    for (const [cityName, count] of Object.entries(dist)) {
      if ((count as number) > 0) {
        verifiedSeoLinks.push({
          label: `${seoLinkLabels[tipo]} en ${cityName}`,
          href: `/comprar/${tipo}/${toSlug(cityName)}`,
        });
      }
    }
  }
  verifiedSeoLinks.sort((a, b) => a.label.localeCompare(b.label));
} catch { /* ignore */ }

// DB-driven SEO content
const faqs = await getPageFAQs(country.code, 'es', 'buy', pais);
const zones = await getPopularZones(country.code, 'es', 'buy', pais);
const propertyTypes = await getPropertyTypes(country.code, 'es', pais);
const infoBox = await getInfoBox(country.code, 'es', 'buy', pais);
const eduCards = await getEducationalCards(country.code, 'es', pais);
const guideHeader = await getGuideHeader(country.code, 'es', 'buy', pais);
const cta = await getCTAContent(country.code, 'es', 'buy', pais);

// Redirect if page is out of bounds
if (currentPage > totalPages && totalPages > 0) {
  return Astro.redirect('/comprar');
}

const pageTitle = tPais(t.pages.buy.title, pais);
const pageDescription = tPais(t.pages.buy.description, pais);

// Schema para listado de propiedades
const listingSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `Propiedades en Venta en ${pais}`,
  description: pageDescription,
  numberOfItems: totalCount,
  itemListElement: properties.slice(0, 10).map((property, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'RealEstateListing',
      name: property.title,
      description: property.description.substring(0, 160),
      url: `https://ubikala.com/propiedad/${property.slug}`,
      image: property.images[0]?.url,
      offers: {
        '@type': 'Offer',
        price: property.price,
        priceCurrency: property.currency,
      },
    },
  })),
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={`comprar casa ${pais.toLowerCase()}, propiedades en venta ${pais.toLowerCase()}, apartamentos venta, casas venta`}
  alternateLanguages={alternateUrls}
>
  <script type="application/ld+json" set:html={JSON.stringify(listingSchema)} slot="head" />

  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Comprar' }
  ]} />

  <!-- Hero -->
  <section class="bg-gradient-to-r from-primary-600 to-primary-700 py-12">
    <div class="container-custom">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Propiedades en Venta en {pais}
      </h1>
      <p class="text-primary-100 text-lg max-w-3xl">
        Explora nuestra selección de casas, apartamentos, villas, terrenos y locales comerciales disponibles para compra en todo el país.
      </p>
    </div>
  </section>

  <!-- Search & Filters -->
  <section class="py-6 bg-white border-b">
    <div class="container-custom">
      <SearchBox variant="compact" locations={searchLocations} />
    </div>
  </section>

  <!-- Results -->
  <section class="section">
    <div class="container-custom">
      <div class="flex items-center justify-between mb-8">
        <div>
          <p class="text-gray-600">
            <span class="font-semibold text-gray-900">{totalCount}</span> propiedades encontradas
          </p>
        </div>
        <div class="flex items-center gap-4">
          <label for="sort" class="text-sm text-gray-600">Ordenar por:</label>
          <select id="sort" class="select py-2 text-sm w-auto">
            <option value="recent">Más recientes</option>
            <option value="price-asc">Precio: menor a mayor</option>
            <option value="price-desc">Precio: mayor a menor</option>
            <option value="area-asc">Área: menor a mayor</option>
            <option value="area-desc">Área: mayor a menor</option>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {properties.map((property) => (
          <PropertyCard property={property} />
        ))}
      </div>

      <!-- Pagination -->
      <div class="mt-12">
        <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/comprar" />
      </div>
    </div>
  </section>

  <!-- SEO Content -->
  <section class="py-16 bg-gradient-to-b from-white to-gray-50">
    <div class="container-custom">
      {guideHeader && (
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{guideHeader.title}</h2>
          {guideHeader.subtitle && <p class="text-lg text-gray-600 max-w-2xl mx-auto">{guideHeader.subtitle}</p>}
        </div>
      )}

      {marketStats && <div class="mb-16"><MarketStatsBar stats={marketStats} operacion="venta" lang="es" countryName={pais} /></div>}

      {(zones.length > 0 || propertyTypes.length > 0) && (
        <div class="grid md:grid-cols-2 gap-12 mb-16">
          {zones.length > 0 && <SEOPopularZones zones={zones} title="Zonas Populares para Comprar" />}
          {propertyTypes.length > 0 && <SEOPropertyTypes types={propertyTypes} />}
        </div>
      )}

      {infoBox && <div class="mb-16"><SEOInfoBox title={infoBox.title} text={infoBox.text} color="green" /></div>}
    </div>
  </section>

  {faqs.length > 0 && <SEOFAQSection faqs={faqs} title="Preguntas Frecuentes sobre Comprar" />}

  {eduCards.length > 0 && (
    <section class="py-12 bg-gray-50">
      <div class="container-custom">
        <SEOEducationalCards cards={eduCards} />
      </div>
    </section>
  )}

  <!-- Deep SEO Links: Only type+city combos with real inventory -->
  {verifiedSeoLinks.length > 0 && (
    <section class="py-12 bg-white">
      <div class="container-custom">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Buscar por Tipo y Ubicacion</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
          {verifiedSeoLinks.map(link => (
            <a href={link.href} class="px-3 py-2.5 bg-gray-50 rounded-lg text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 transition-colors text-center">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  {cta ? (
    <section class="py-12 bg-gradient-to-r from-primary-600 to-primary-700">
      <div class="container-custom text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">{cta.title}</h2>
        <p class="text-primary-100 mb-6 max-w-xl mx-auto">{cta.description}</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contacto" class="inline-flex items-center justify-center gap-2 bg-white text-primary-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            Contactanos
          </a>
        </div>
      </div>
    </section>
  ) : (
    <section class="py-12 bg-gradient-to-r from-primary-600 to-primary-700">
      <div class="container-custom text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
          ¿Listo para encontrar tu propiedad ideal?
        </h2>
        <p class="text-primary-100 mb-6 max-w-xl mx-auto">
          Te ayudamos a encontrar la mejor opcion para ti.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contacto" class="inline-flex items-center justify-center gap-2 bg-white text-primary-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            Contactanos
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- FAQ Schema -->
  {faqs.length > 0 && <script is:inline type="application/ld+json" set:html={JSON.stringify(getFAQSchema(faqs))} />}
</Layout>
