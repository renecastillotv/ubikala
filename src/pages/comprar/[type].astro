---
import Layout from '../../layouts/Layout.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import SearchBox from '../../components/SearchBox.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { useTranslations } from '../../i18n';
import { searchProperties, getCitiesWithCounts } from '../../lib/meilisearch';
import { toSlug } from '../../lib/slug-utils';
import type { Property, PropertyType } from '../../data/types';

// SSR para páginas dinámicas por tipo
export const prerender = false;

// Mapeo de slugs URL a tipos de base de datos
const slugToDbType: Record<string, string> = {
  'casas': 'casa',
  'apartamentos': 'apartamento',
  'villas': 'villa',
  'penthouses': 'penthouse',
  'terrenos': 'terreno',
  'locales-comerciales': 'local',
  'oficinas': 'oficina',
  'almacenes': 'nave',
  'edificios': 'edificio',
  'solares': 'solar',
};

const typeNames: Record<string, string> = {
  'casas': 'Casas',
  'apartamentos': 'Apartamentos',
  'villas': 'Villas',
  'penthouses': 'Penthouses',
  'terrenos': 'Terrenos',
  'locales-comerciales': 'Locales Comerciales',
  'oficinas': 'Oficinas',
  'almacenes': 'Almacenes',
  'edificios': 'Edificios',
  'solares': 'Solares',
};

const { type: typeSlug } = Astro.params;
const t = useTranslations('es');

const pais = Astro.locals.country.name;

const typeDescriptions: Record<string, string> = {
  'casas': `Encuentra casas en venta en ${pais}. Desde residencias familiares hasta propiedades de lujo en las mejores zonas del país.`,
  'apartamentos': `Explora apartamentos en venta en ${pais}. Modernos, con amenidades y ubicaciones privilegiadas.`,
  'villas': `Descubre villas exclusivas en ${pais}. Frente al mar, en campos de golf y comunidades cerradas.`,
  'penthouses': `Los penthouses más espectaculares de ${pais}. Vistas panorámicas, terrazas privadas y acabados de primera.`,
  'terrenos': `Terrenos en venta en ${pais}. Lotes residenciales, comerciales e industriales en ubicaciones estratégicas.`,
  'locales-comerciales': `Locales comerciales en las mejores zonas de ${pais}. Ideales para restaurantes, tiendas, oficinas y más.`,
  'oficinas': `Espacios de oficina en ${pais}. Torres empresariales y edificios comerciales listos para tu negocio.`,
  'almacenes': `Naves industriales y almacenes en ${pais}.`,
  'edificios': `Edificios completos en venta en ${pais} para inversión o desarrollo.`,
  'solares': `Solares en venta en ${pais} para construir tu proyecto ideal.`,
};

const dbType = slugToDbType[typeSlug || ''] || typeSlug;
const typeName = typeNames[typeSlug || ''] || typeSlug?.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) || 'Propiedades';
const typeDescription = typeDescriptions[typeSlug || ''] || `Encuentra ${typeName.toLowerCase()} en venta en ${pais}.`;

// Read advanced filter query params
const precioParam = Astro.url.searchParams.get('precio');
const habitacionesParam = Astro.url.searchParams.get('habitaciones');
const banosParam = Astro.url.searchParams.get('banos');

let precioMin: number | undefined;
let precioMax: number | undefined;
if (precioParam) {
  if (precioParam.endsWith('+')) {
    precioMin = parseInt(precioParam);
  } else if (precioParam.includes('-')) {
    const [min, max] = precioParam.split('-').map(Number);
    precioMin = min || undefined;
    precioMax = max || undefined;
  }
}

// Fetch properties from MeiliSearch
let typeProperties: Property[] = [];
let totalCount = 0;
try {
  const result = await searchProperties({
    tipo: dbType,
    operacion: 'venta',
    precioMin,
    precioMax,
    habitacionesMin: habitacionesParam ? parseInt(habitacionesParam) : undefined,
    banosMin: banosParam ? parseInt(banosParam) : undefined,
    limit: 24,
    pais,
  });
  typeProperties = result.properties;
  totalCount = result.total;
} catch (error) {
  console.error('Error fetching properties by type:', error);
}

// Fetch cities that have this property type for sale (dynamic SEO links)
let citiesWithType: Array<{ name: string; slug: string; count: number }> = [];
try {
  const cityResult = await searchProperties({
    tipo: dbType,
    operacion: 'venta',
    pais,
    limit: 0,
    facets: ['ciudad'],
  });
  const distribution = cityResult.facetDistribution?.ciudad || {};
  citiesWithType = Object.entries(distribution)
    .map(([name, count]) => ({ name, slug: toSlug(name), count: count as number }))
    .sort((a, b) => b.count - a.count)
    .slice(0, 12);
} catch { /* ignore */ }

const pageTitle = `${typeName} en Venta en ${pais} | Ubíkala.com`;
---

<Layout
  title={pageTitle}
  description={typeDescription}
  keywords={`${typeName.toLowerCase()} en venta republica dominicana, comprar ${typeName.toLowerCase()} rd, ${typeName.toLowerCase()} santo domingo, ${typeName.toLowerCase()} punta cana`}
>
  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Comprar', href: '/comprar' },
    { label: typeName }
  ]} />

  <!-- Hero -->
  <section class="bg-gradient-to-r from-primary-600 to-primary-700 py-12">
    <div class="container-custom">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
        {typeName} en Venta en {pais}
      </h1>
      <p class="text-primary-100 text-lg max-w-3xl">
        {typeDescription}
      </p>
    </div>
  </section>

  <!-- Search -->
  <section class="py-8 bg-white shadow-sm">
    <div class="container-custom">
      <SearchBox variant="compact" />
    </div>
  </section>

  <!-- Results -->
  <section class="section">
    <div class="container-custom">
      <div class="flex items-center justify-between mb-8">
        <p class="text-gray-600">
          <span class="font-semibold text-gray-900">{totalCount}</span> {typeName.toLowerCase()} encontradas
        </p>
        <select class="select py-2 text-sm w-auto">
          <option value="recent">Más recientes</option>
          <option value="price-asc">Precio: menor a mayor</option>
          <option value="price-desc">Precio: mayor a menor</option>
        </select>
      </div>

      {typeProperties.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {typeProperties.map((property) => (
            <PropertyCard property={property} />
          ))}
        </div>
      ) : (
        <div class="card p-12 text-center">
          <p class="text-gray-600 mb-4">No hay {typeName.toLowerCase()} disponibles en este momento.</p>
          <a href="/comprar" class="btn-primary">Ver todas las propiedades</a>
        </div>
      )}
    </div>
  </section>

  <!-- Dynamic city links for this property type -->
  {citiesWithType.length > 0 && (
    <section class="py-12 bg-gray-50">
      <div class="container-custom">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">
          {typeName} en Venta por Ciudad
        </h2>
        <p class="text-gray-600 mb-8">
          Explora {typeName.toLowerCase()} disponibles en las principales ciudades de {pais}.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {citiesWithType.map((city) => (
            <a
              href={`/comprar/${typeSlug}/${city.slug}`}
              class="bg-white rounded-xl p-4 shadow-sm hover:shadow-md transition-shadow group"
            >
              <span class="font-semibold text-gray-900 group-hover:text-primary-600 block">
                {city.name}
              </span>
              <span class="text-sm text-gray-500">{city.count} {typeName.toLowerCase()}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
