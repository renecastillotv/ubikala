---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getSiteConfig } from '../../lib/config';

const config = await getSiteConfig(Astro.locals.country?.code);

// Article Schema for SEO
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bono Primera Vivienda en Republica Dominicana",
  "description": "Guia completa sobre el Bono de Primera Vivienda en Republica Dominicana. Requisitos, montos, proceso de solicitud y todo lo que necesitas saber para obtener el subsidio habitacional.",
  "image": `${config.site_url}/images/guias/bono-vivienda.jpg`,
  "author": {
    "@type": "Organization",
    "name": config.company_name,
    "url": config.site_url
  },
  "publisher": {
    "@type": "Organization",
    "name": config.company_name,
    "logo": {
      "@type": "ImageObject",
      "url": `${config.site_url}${config.logo_url}`
    }
  },
  "datePublished": "2024-01-15",
  "dateModified": new Date().toISOString().split('T')[0],
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${config.site_url}/guias/bono-primera-vivienda`
  }
};

// FAQ Schema for SEO
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Que es el Bono de Primera Vivienda en Republica Dominicana?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El Bono de Primera Vivienda es un subsidio del gobierno dominicano, administrado por el Ministerio de la Vivienda y Edificaciones, que otorga hasta RD$1,500,000 a familias de bajos y medianos ingresos para la compra de su primera vivienda. Esta regulado por la Ley 189-11 de Fideicomisos."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuanto dinero puedo recibir con el Bono de Primera Vivienda?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El monto del subsidio depende del valor de la vivienda y los ingresos familiares. Para viviendas de bajo costo (hasta RD$2,500,000), el bono puede cubrir hasta RD$1,500,000. Para viviendas de costo moderado (hasta RD$4,500,000), el subsidio es menor y se calcula segun la capacidad de pago."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuales son los requisitos para solicitar el Bono de Primera Vivienda?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Los requisitos principales son: ser dominicano o residente legal, ser mayor de edad, no poseer ninguna propiedad inmobiliaria a tu nombre, tener ingresos familiares dentro de los limites establecidos, y la vivienda debe estar en un proyecto registrado bajo fideicomiso (Ley 189-11)."
      }
    },
    {
      "@type": "Question",
      "name": "¿Como solicito el Bono de Primera Vivienda?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Debes elegir un proyecto habitacional registrado bajo fideicomiso, reunir los documentos requeridos (cedula, carta de trabajo, estados de cuenta, certificacion de no propiedad), y realizar la solicitud a traves de la entidad fiduciaria del proyecto o directamente en el Ministerio de la Vivienda."
      }
    }
  ]
};
---

<Layout
  title={`Bono Primera Vivienda en RD | ${config.company_name}`}
  description="Guia completa sobre el Bono de Primera Vivienda en Republica Dominicana. Requisitos, montos de hasta RD$1,500,000, proceso de solicitud y documentos necesarios."
  keywords="bono primera vivienda, subsidio vivienda republica dominicana, bono vivienda rd, primera casa rd, subsidio habitacional"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Guias', href: '/guias' },
    { label: 'Bono Primera Vivienda' }
  ]} />

  <!-- Hero -->
  <section class="bg-gradient-to-r from-primary-600 to-primary-700 py-12">
    <div class="container-custom">
      <span class="inline-block px-3 py-1 bg-white/20 rounded-full text-white text-sm mb-4">Subsidio Gubernamental</span>
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Bono de Primera Vivienda en Republica Dominicana
      </h1>
      <p class="text-primary-100 text-lg max-w-3xl">
        Recibe hasta RD$1,500,000 de subsidio del gobierno para comprar tu primera casa. Conoce los requisitos, el proceso y como aplicar.
      </p>
    </div>
  </section>

  <!-- Content -->
  <article class="section">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <!-- Table of Contents -->
        <div class="bg-gray-50 rounded-lg p-6 mb-8">
          <h2 class="font-semibold text-gray-900 mb-4">Contenido</h2>
          <ul class="space-y-2 text-sm">
            <li><a href="#que-es" class="text-primary-600 hover:underline">¿Que es el Bono de Primera Vivienda?</a></li>
            <li><a href="#montos" class="text-primary-600 hover:underline">Montos del Subsidio</a></li>
            <li><a href="#requisitos" class="text-primary-600 hover:underline">Requisitos para Aplicar</a></li>
            <li><a href="#documentos" class="text-primary-600 hover:underline">Documentos Necesarios</a></li>
            <li><a href="#proceso" class="text-primary-600 hover:underline">Proceso de Solicitud</a></li>
            <li><a href="#tipos-vivienda" class="text-primary-600 hover:underline">Tipos de Vivienda Elegibles</a></li>
            <li><a href="#consideraciones" class="text-primary-600 hover:underline">Consideraciones Importantes</a></li>
          </ul>
        </div>

        <!-- Section: Que es -->
        <section id="que-es" class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">¿Que es el Bono de Primera Vivienda?</h2>
          <p class="text-gray-700 mb-4">
            El Bono de Primera Vivienda es un <strong>subsidio habitacional</strong> otorgado por el gobierno dominicano a traves del Ministerio de la Vivienda y Edificaciones (MIVED). Esta disenado para ayudar a familias de bajos y medianos ingresos a adquirir su primera propiedad.
          </p>
          <p class="text-gray-700 mb-4">
            El programa esta amparado por la <strong>Ley 189-11</strong> sobre el Desarrollo del Mercado Hipotecario y el Fideicomiso en Republica Dominicana, que establece el marco legal para los subsidios habitacionales.
          </p>
          <div class="bg-primary-50 border-l-4 border-primary-500 p-4 my-6">
            <p class="text-primary-800">
              <strong>Dato clave:</strong> El bono no es un prestamo, es un subsidio directo que no tienes que devolver. Se aplica como pago inicial o complemento para reducir el monto de tu hipoteca.
            </p>
          </div>
        </section>

        <!-- Section: Montos -->
        <section id="montos" class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Montos del Subsidio</h2>
          <p class="text-gray-700 mb-4">
            El monto del bono depende del tipo de vivienda y los ingresos familiares:
          </p>

          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-gray-100">
                  <th class="border p-3 font-semibold">Tipo de Vivienda</th>
                  <th class="border p-3 font-semibold">Valor Maximo</th>
                  <th class="border p-3 font-semibold">Subsidio Aproximado</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="border p-3">Vivienda de bajo costo</td>
                  <td class="border p-3">Hasta RD$2,500,000</td>
                  <td class="border p-3 font-semibold text-green-700">Hasta RD$1,500,000</td>
                </tr>
                <tr class="bg-gray-50">
                  <td class="border p-3">Vivienda de costo moderado</td>
                  <td class="border p-3">RD$2,500,000 - RD$4,500,000</td>
                  <td class="border p-3 font-semibold text-green-700">Hasta RD$750,000</td>
                </tr>
                <tr>
                  <td class="border p-3">Vivienda de costo medio</td>
                  <td class="border p-3">RD$4,500,000 - RD$6,500,000</td>
                  <td class="border p-3 font-semibold text-green-700">Hasta RD$400,000</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="bg-green-50 border-l-4 border-green-500 p-4 mt-6">
            <p class="text-green-800">
              <strong>Beneficio adicional:</strong> Las viviendas adquiridas bajo fideicomiso (Ley 189-11) pueden estar exentas del 3% de impuesto de transferencia inmobiliaria, lo que representa un ahorro adicional significativo.
            </p>
          </div>
        </section>

        <!-- Section: Requisitos -->
        <section id="requisitos" class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Requisitos para Aplicar</h2>

          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-white border rounded-lg p-6">
              <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Requisitos Personales</h3>
              <ul class="text-sm text-gray-600 space-y-2">
                <li>• Ser dominicano o residente legal</li>
                <li>• Mayor de 18 anos</li>
                <li>• No poseer ninguna propiedad inmobiliaria</li>
                <li>• No haber recibido subsidio habitacional previo</li>
              </ul>
            </div>

            <div class="bg-white border rounded-lg p-6">
              <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Requisitos Economicos</h3>
              <ul class="text-sm text-gray-600 space-y-2">
                <li>• Ingresos familiares dentro de los limites del programa</li>
                <li>• Capacidad de pago demostrable</li>
                <li>• Historial crediticio favorable (no indispensable)</li>
                <li>• Cuenta de ahorro activa</li>
              </ul>
            </div>

            <div class="bg-white border rounded-lg p-6">
              <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Requisitos de la Vivienda</h3>
              <ul class="text-sm text-gray-600 space-y-2">
                <li>• Proyecto registrado bajo fideicomiso (Ley 189-11)</li>
                <li>• Valor dentro de los limites del programa</li>
                <li>• Vivienda nueva (no aplica para propiedades usadas)</li>
                <li>• Proyecto aprobado por el MIVED</li>
              </ul>
            </div>

            <div class="bg-white border rounded-lg p-6">
              <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Condiciones</h3>
              <ul class="text-sm text-gray-600 space-y-2">
                <li>• No vender la vivienda por al menos 5 anos</li>
                <li>• Usar la vivienda como residencia principal</li>
                <li>• No alquilar la propiedad durante el periodo de restriccion</li>
                <li>• Mantener el inmueble en buen estado</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Section: Documentos -->
        <section id="documentos" class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Documentos Necesarios</h2>

          <div class="bg-white border rounded-lg divide-y">
            <div class="p-4 flex items-start gap-3">
              <span class="flex-shrink-0 w-6 h-6 bg-primary-100 text-primary-600 rounded-full flex items-center justify-center text-sm font-bold">1</span>
              <div>
                <p class="font-medium text-gray-900">Cedula de identidad y electoral</p>
                <p class="text-sm text-gray-600">Original y copia del solicitante y conyugue (si aplica)</p>
              </div>
            </div>
            <div class="p-4 flex items-start gap-3">
              <span class="flex-shrink-0 w-6 h-6 bg-primary-100 text-primary-600 rounded-full flex items-center justify-center text-sm font-bold">2</span>
              <div>
                <p class="font-medium text-gray-900">Carta de trabajo</p>
                <p class="text-sm text-gray-600">Emitida por el empleador, indicando cargo, salario y tiempo laborando</p>
              </div>
            </div>
            <div class="p-4 flex items-start gap-3">
              <span class="flex-shrink-0 w-6 h-6 bg-primary-100 text-primary-600 rounded-full flex items-center justify-center text-sm font-bold">3</span>
              <div>
                <p class="font-medium text-gray-900">Estados de cuenta bancarios</p>
                <p class="text-sm text-gray-600">Ultimos 3 a 6 meses de cuentas de ahorro y/o corrientes</p>
              </div>
            </div>
            <div class="p-4 flex items-start gap-3">
              <span class="flex-shrink-0 w-6 h-6 bg-primary-100 text-primary-600 rounded-full flex items-center justify-center text-sm font-bold">4</span>
              <div>
                <p class="font-medium text-gray-900">Certificacion de no propiedad</p>
                <p class="text-sm text-gray-600">Emitida por la Jurisdiccion Inmobiliaria, confirmando que no posees inmuebles</p>
              </div>
            </div>
            <div class="p-4 flex items-start gap-3">
              <span class="flex-shrink-0 w-6 h-6 bg-primary-100 text-primary-600 rounded-full flex items-center justify-center text-sm font-bold">5</span>
              <div>
                <p class="font-medium text-gray-900">Certificacion de la DGII</p>
                <p class="text-sm text-gray-600">Indicando que no posees bienes inmuebles registrados</p>
              </div>
            </div>
            <div class="p-4 flex items-start gap-3">
              <span class="flex-shrink-0 w-6 h-6 bg-primary-100 text-primary-600 rounded-full flex items-center justify-center text-sm font-bold">6</span>
              <div>
                <p class="font-medium text-gray-900">Acta de matrimonio o declaracion jurada de solteria</p>
                <p class="text-sm text-gray-600">Segun tu estado civil actual</p>
              </div>
            </div>
            <div class="p-4 flex items-start gap-3">
              <span class="flex-shrink-0 w-6 h-6 bg-primary-100 text-primary-600 rounded-full flex items-center justify-center text-sm font-bold">7</span>
              <div>
                <p class="font-medium text-gray-900">Formulario de solicitud del MIVED</p>
                <p class="text-sm text-gray-600">Disponible en las oficinas del Ministerio de la Vivienda o en el proyecto</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Section: Proceso -->
        <section id="proceso" class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Proceso de Solicitud</h2>

          <ol class="space-y-6">
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</span>
              <div>
                <h4 class="font-semibold text-gray-900">Elige un Proyecto Elegible</h4>
                <p class="text-gray-600">Busca un proyecto habitacional registrado bajo fideicomiso y aprobado por el MIVED. En Ubikala puedes filtrar propiedades que aplican al bono.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</span>
              <div>
                <h4 class="font-semibold text-gray-900">Reune los Documentos</h4>
                <p class="text-gray-600">Prepara todos los documentos requeridos. La certificacion de no propiedad puedes solicitarla en la Jurisdiccion Inmobiliaria de tu zona.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</span>
              <div>
                <h4 class="font-semibold text-gray-900">Presenta la Solicitud</h4>
                <p class="text-gray-600">Entrega tu solicitud y documentos en la oficina de ventas del proyecto o directamente en el MIVED. Algunos proyectos gestionan el proceso por ti.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</span>
              <div>
                <h4 class="font-semibold text-gray-900">Evaluacion y Aprobacion</h4>
                <p class="text-gray-600">El MIVED evalua tu solicitud y verifica que cumplas los requisitos. Este proceso puede tomar de 2 a 8 semanas.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</span>
              <div>
                <h4 class="font-semibold text-gray-900">Desembolso del Bono</h4>
                <p class="text-gray-600">Una vez aprobado, el bono se deposita directamente en la cuenta del fideicomiso del proyecto, reduciendo el monto que debes financiar.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</span>
              <div>
                <h4 class="font-semibold text-gray-900">Cierre y Entrega</h4>
                <p class="text-gray-600">Completa el financiamiento restante (hipoteca o pagos al proyecto) y al finalizar la construccion recibes tu vivienda.</p>
              </div>
            </li>
          </ol>
        </section>

        <!-- Section: Tipos de vivienda -->
        <section id="tipos-vivienda" class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Tipos de Vivienda Elegibles</h2>

          <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-white border rounded-lg p-6 text-center">
              <div class="text-3xl font-bold text-primary-600 mb-2">Bajo Costo</div>
              <p class="text-sm text-gray-600 mb-3">Hasta RD$2,500,000</p>
              <div class="bg-green-100 text-green-800 rounded-full px-3 py-1 text-sm font-medium inline-block">
                Mayor subsidio
              </div>
              <p class="text-sm text-gray-600 mt-3">Apartamentos y casas en proyectos de interes social. Ideal para familias de bajos ingresos.</p>
            </div>

            <div class="bg-white border rounded-lg p-6 text-center">
              <div class="text-3xl font-bold text-primary-600 mb-2">Costo Moderado</div>
              <p class="text-sm text-gray-600 mb-3">RD$2.5M - RD$4.5M</p>
              <div class="bg-blue-100 text-blue-800 rounded-full px-3 py-1 text-sm font-medium inline-block">
                Subsidio parcial
              </div>
              <p class="text-sm text-gray-600 mt-3">Apartamentos en torres y casas en urbanizaciones. Para familias de ingresos medios.</p>
            </div>

            <div class="bg-white border rounded-lg p-6 text-center">
              <div class="text-3xl font-bold text-primary-600 mb-2">Costo Medio</div>
              <p class="text-sm text-gray-600 mb-3">RD$4.5M - RD$6.5M</p>
              <div class="bg-gray-100 text-gray-800 rounded-full px-3 py-1 text-sm font-medium inline-block">
                Subsidio menor
              </div>
              <p class="text-sm text-gray-600 mt-3">Apartamentos en zonas de mayor demanda. Subsidio complementario al inicial.</p>
            </div>
          </div>
        </section>

        <!-- Section: Consideraciones -->
        <section id="consideraciones" class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Consideraciones Importantes</h2>

          <div class="space-y-4">
            <div class="bg-yellow-50 border-l-4 border-yellow-500 p-4">
              <h4 class="font-semibold text-yellow-800 mb-2">Solo Viviendas Nuevas</h4>
              <p class="text-yellow-700">El bono aplica exclusivamente para viviendas nuevas en proyectos bajo fideicomiso. No se puede usar para comprar propiedades usadas o en el mercado secundario.</p>
            </div>

            <div class="bg-yellow-50 border-l-4 border-yellow-500 p-4">
              <h4 class="font-semibold text-yellow-800 mb-2">Restriccion de Venta</h4>
              <p class="text-yellow-700">No puedes vender, alquilar o transferir la vivienda durante los primeros 5 anos despues de adquirida. Si lo haces, debes devolver el monto del subsidio.</p>
            </div>

            <div class="bg-yellow-50 border-l-4 border-yellow-500 p-4">
              <h4 class="font-semibold text-yellow-800 mb-2">Una Sola Vez</h4>
              <p class="text-yellow-700">El bono es un beneficio unico. Solo puedes solicitarlo una vez en la vida, asi que asegurate de elegir bien tu vivienda.</p>
            </div>

            <div class="bg-yellow-50 border-l-4 border-yellow-500 p-4">
              <h4 class="font-semibold text-yellow-800 mb-2">Disponibilidad de Fondos</h4>
              <p class="text-yellow-700">Los fondos del bono estan sujetos a la disponibilidad presupuestaria del gobierno. El proceso puede variar en tiempos segun la demanda y los recursos disponibles.</p>
            </div>
          </div>
        </section>

        <!-- CTA -->
        <div class="bg-gray-50 rounded-lg p-8 text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-4">¿Listo para Comprar tu Primera Vivienda?</h3>
