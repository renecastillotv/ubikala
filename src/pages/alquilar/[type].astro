---
import Layout from '../../layouts/Layout.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import SearchBox from '../../components/SearchBox.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { useTranslations } from '../../i18n';
import { searchProperties } from '../../lib/meilisearch';
import { toSlug } from '../../lib/slug-utils';
import type { Property } from '../../data/types';

export const prerender = false;

const slugToDbType: Record<string, string> = {
  'casas': 'casa',
  'apartamentos': 'apartamento',
  'villas': 'villa',
  'penthouses': 'penthouse',
  'terrenos': 'terreno',
  'locales-comerciales': 'local',
  'oficinas': 'oficina',
  'almacenes': 'nave',
  'edificios': 'edificio',
  'solares': 'solar',
  'estudios': 'estudio',
};

const typeNames: Record<string, string> = {
  'casas': 'Casas',
  'apartamentos': 'Apartamentos',
  'villas': 'Villas',
  'penthouses': 'Penthouses',
  'terrenos': 'Terrenos',
  'locales-comerciales': 'Locales Comerciales',
  'oficinas': 'Oficinas',
  'almacenes': 'Almacenes',
  'edificios': 'Edificios',
  'solares': 'Solares',
  'estudios': 'Estudios',
};

const { type: typeSlug } = Astro.params;
const t = useTranslations('es');
const pais = Astro.locals.country.name;

const typeDescriptions: Record<string, string> = {
  'casas': `Casas en alquiler en ${pais}. Residencias familiares con espacio, seguridad y comodidad.`,
  'apartamentos': `Apartamentos en alquiler en ${pais}. Modernos, amueblados y sin amueblar en las mejores zonas.`,
  'villas': `Villas en alquiler en ${pais}. Propiedades exclusivas para vacaciones o residencia de lujo.`,
  'penthouses': `Penthouses en alquiler en ${pais}. Vistas panoramicas, terrazas privadas y acabados premium.`,
  'oficinas': `Oficinas en alquiler en ${pais}. Espacios comerciales listos para tu negocio.`,
  'locales-comerciales': `Locales comerciales en alquiler en ${pais}. Ubicaciones estrategicas para tu emprendimiento.`,
  'almacenes': `Naves industriales y almacenes en alquiler en ${pais}.`,
  'estudios': `Estudios en alquiler en ${pais}. Espacios compactos ideales para solteros y parejas.`,
};

const dbType = slugToDbType[typeSlug || ''] || typeSlug;
const typeName = typeNames[typeSlug || ''] || typeSlug?.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) || 'Propiedades';
const typeDescription = typeDescriptions[typeSlug || ''] || `Encuentra ${typeName.toLowerCase()} en alquiler en ${pais}.`;

// Read advanced filter query params
const precioParam = Astro.url.searchParams.get('precio');
const habitacionesParam = Astro.url.searchParams.get('habitaciones');
const banosParam = Astro.url.searchParams.get('banos');

let precioMin: number | undefined;
let precioMax: number | undefined;
if (precioParam) {
  if (precioParam.endsWith('+')) {
    precioMin = parseInt(precioParam);
  } else if (precioParam.includes('-')) {
    const [min, max] = precioParam.split('-').map(Number);
    precioMin = min || undefined;
    precioMax = max || undefined;
  }
}

// Fetch properties
let typeProperties: Property[] = [];
let totalCount = 0;
try {
  const result = await searchProperties({
    tipo: dbType,
    operacion: 'renta',
    precioMin,
    precioMax,
    habitacionesMin: habitacionesParam ? parseInt(habitacionesParam) : undefined,
    banosMin: banosParam ? parseInt(banosParam) : undefined,
    limit: 24,
    pais,
  });
  typeProperties = result.properties;
  totalCount = result.total;
} catch (error) {
  console.error('Error fetching rental properties by type:', error);
}

// Fetch cities with this type for rent
let citiesWithType: Array<{ name: string; slug: string; count: number }> = [];
try {
  const cityResult = await searchProperties({
    tipo: dbType,
    operacion: 'renta',
    pais,
    limit: 0,
    facets: ['ciudad'],
  });
  const distribution = cityResult.facetDistribution?.ciudad || {};
  citiesWithType = Object.entries(distribution)
    .map(([name, count]) => ({ name, slug: toSlug(name), count: count as number }))
    .sort((a, b) => b.count - a.count)
    .slice(0, 12);
} catch { /* ignore */ }

const pageTitle = `${typeName} en Alquiler en ${pais} | Ubikala.com`;

const listingSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${typeName} en Alquiler en ${pais}`,
  description: typeDescription,
  numberOfItems: totalCount,
  itemListElement: typeProperties.slice(0, 10).map((property, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'RealEstateListing',
      name: property.title,
      url: `https://ubikala.com/propiedad/${property.slug}`,
      image: property.images[0]?.url,
      offers: {
        '@type': 'Offer',
        price: property.price,
        priceCurrency: property.currency,
      },
    },
  })),
};
---

<Layout
  title={pageTitle}
  description={typeDescription}
  keywords={`${typeName.toLowerCase()} en alquiler ${pais.toLowerCase()}, rentar ${typeName.toLowerCase()} ${pais.toLowerCase()}${citiesWithType.length > 0 ? `, ${typeName.toLowerCase()} ${citiesWithType[0].name.toLowerCase()}` : ''}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(listingSchema)} slot="head" />
  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Alquilar', href: '/alquilar' },
    { label: typeName }
  ]} />

  <!-- Hero -->
  <section class="bg-gradient-to-r from-secondary-600 to-secondary-700 py-12">
    <div class="container-custom">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
        {typeName} en Alquiler en {pais}
      </h1>
      <p class="text-secondary-100 text-lg max-w-3xl">
        {typeDescription}
      </p>
    </div>
  </section>

  <!-- Search -->
  <section class="py-8 bg-white shadow-sm">
    <div class="container-custom">
      <SearchBox variant="compact" />
    </div>
  </section>

  <!-- Results -->
  <section class="section">
    <div class="container-custom">
      <div class="flex items-center justify-between mb-8">
        <p class="text-gray-600">
          <span class="font-semibold text-gray-900">{totalCount}</span> {typeName.toLowerCase()} encontradas
        </p>
        <select class="select py-2 text-sm w-auto">
          <option value="recent">Mas recientes</option>
          <option value="price-asc">Precio: menor a mayor</option>
          <option value="price-desc">Precio: mayor a menor</option>
        </select>
      </div>

      {typeProperties.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {typeProperties.map((property) => (
            <PropertyCard property={property} />
          ))}
        </div>
      ) : (
        <div class="card p-12 text-center">
          <p class="text-gray-600 mb-4">No hay {typeName.toLowerCase()} en alquiler disponibles en este momento.</p>
          <a href="/alquilar" class="bg-secondary-600 text-white hover:bg-secondary-700 font-semibold px-6 py-3 rounded-lg transition-colors">
            Ver todas las propiedades en alquiler
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- Dynamic city links -->
  {citiesWithType.length > 0 && (
    <section class="py-12 bg-gray-50">
      <div class="container-custom">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">
          {typeName} en Alquiler por Ciudad
        </h2>
        <p class="text-gray-600 mb-8">
          Explora {typeName.toLowerCase()} en alquiler en las principales ciudades de {pais}.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {citiesWithType.map((city) => (
            <a
              href={`/alquilar/${typeSlug}/${city.slug}`}
              class="bg-white rounded-xl p-4 shadow-sm hover:shadow-md transition-shadow group"
            >
              <span class="font-semibold text-gray-900 group-hover:text-secondary-600 block">
                {city.name}
              </span>
              <span class="text-sm text-gray-500">{city.count} {typeName.toLowerCase()}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
