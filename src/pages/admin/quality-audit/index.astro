---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const user = Astro.locals.user;

if (!user || user.role !== 'admin') {
  return Astro.redirect('/admin/dashboard');
}
---

<AdminLayout title="Auditoría de Calidad">
  <div class="audit-page">
    <div class="page-header">
      <div>
        <h2>Auditoría de Calidad</h2>
        <p class="subtitle">Verifica la calidad de todas las propiedades publicadas en Ubikala</p>
      </div>
      <button id="run-audit" class="btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="btn-icon">
          <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Ejecutar Auditoría
      </button>
    </div>

    <!-- Stats -->
    <div class="stats-row" id="stats-row" style="display:none">
      <div class="stat-card total">
        <span class="stat-number" id="stat-total">0</span>
        <span class="stat-label">Total</span>
      </div>
      <div class="stat-card passing">
        <span class="stat-number" id="stat-passing">0</span>
        <span class="stat-label">OK</span>
      </div>
      <div class="stat-card failing">
        <span class="stat-number" id="stat-failing">0</span>
        <span class="stat-label">Errores</span>
      </div>
      <div class="stat-card warnings">
        <span class="stat-number" id="stat-warnings">0</span>
        <span class="stat-label">Avisos</span>
      </div>
    </div>

    <!-- Filters -->
    <div class="filters-bar" id="filters-bar" style="display:none">
      <select id="filter-severity">
        <option value="all">Todos</option>
        <option value="errors">Con errores</option>
        <option value="warnings">Solo avisos</option>
        <option value="clean">Sin problemas</option>
        <option value="duplicates">Duplicados</option>
      </select>
      <select id="filter-issue">
        <option value="all">Todos los problemas</option>
      </select>
      <span class="results-count" id="results-count"></span>
    </div>

    <!-- Loading -->
    <div class="loading-state" id="loading-state" style="display:none">
      <div class="spinner"></div>
      <p>Analizando propiedades...</p>
    </div>

    <!-- Empty state -->
    <div class="empty-state" id="empty-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
      </svg>
      <h3>Ejecuta la auditoría</h3>
      <p>Analiza todas las propiedades publicadas en busca de problemas de calidad.</p>
    </div>

    <!-- Results -->
    <div id="results-container" style="display:none"></div>

    <!-- Breakdown -->
    <div class="breakdown-section" id="breakdown-section" style="display:none">
      <h3>Resumen de Problemas</h3>
      <div class="breakdown-grid" id="breakdown-grid"></div>
    </div>
  </div>

  <!-- Confirm modal -->
  <div class="modal-overlay" id="modal-overlay" style="display:none">
    <div class="modal-box">
      <h3 id="modal-title">Confirmar</h3>
      <p id="modal-message"></p>
      <div class="modal-actions">
        <button class="btn-cancel" id="modal-cancel">Cancelar</button>
        <button class="btn-danger" id="modal-confirm">Confirmar</button>
      </div>
    </div>
  </div>

  <style>
    .audit-page { max-width: 1200px; }
    .page-header {
      display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px;
    }
    .page-header h2 { font-size: 1.25rem; font-weight: 700; color: #111827; margin: 0 0 4px; }
    .subtitle { font-size: 0.8125rem; color: #6B7280; margin: 0; }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px;
      background: var(--ubikala-olive); color: #fff; border: none; border-radius: 8px;
      font-size: 0.8125rem; font-weight: 600; cursor: pointer;
    }
    .btn-primary:hover { background: var(--ubikala-olive-dark); }
    .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
    .btn-icon { width: 18px; height: 18px; }

    .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }
    .stat-card {
      background: #fff; border: 1px solid #E5E7EB; border-radius: 10px;
      padding: 16px; border-left: 4px solid #E5E7EB;
    }
    .stat-card.total { border-left-color: #6366F1; }
    .stat-card.passing { border-left-color: #10B981; }
    .stat-card.failing { border-left-color: #EF4444; }
    .stat-card.warnings { border-left-color: #F59E0B; }
    .stat-number { display: block; font-size: 1.5rem; font-weight: 700; color: #111827; }
    .stat-label { font-size: 0.6875rem; color: #6B7280; text-transform: uppercase; letter-spacing: 0.05em; }

    .filters-bar {
      display: flex; align-items: center; gap: 12px; margin-bottom: 16px;
      padding: 10px 16px; background: #F9FAFB; border: 1px solid #E5E7EB; border-radius: 8px;
    }
    .filters-bar select {
      padding: 5px 10px; border: 1px solid #D1D5DB; border-radius: 6px;
      font-size: 0.75rem; color: #374151; background: #fff;
    }
    .results-count { margin-left: auto; font-size: 0.6875rem; color: #6B7280; }

    .loading-state { text-align: center; padding: 60px 20px; color: #6B7280; }
    .spinner {
      width: 36px; height: 36px; border: 3px solid #E5E7EB; border-top-color: var(--ubikala-olive);
      border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 12px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .empty-state { text-align: center; padding: 60px 20px; color: #6B7280; }
    .empty-state svg { width: 48px; height: 48px; margin: 0 auto 12px; color: #D1D5DB; }
    .empty-state h3 { font-size: 1rem; color: #374151; margin: 0 0 6px; }

    /* Card-based results */
    .property-card {
      display: flex; align-items: flex-start; gap: 14px;
      background: #fff; border: 1px solid #E5E7EB; border-radius: 10px;
      padding: 14px; margin-bottom: 8px; transition: border-color 0.2s;
    }
    .property-card:hover { border-color: #D1D5DB; }
    .property-card.removed { opacity: 0.4; pointer-events: none; }
    .property-card.has-errors { border-left: 3px solid #EF4444; }
    .property-card.has-warnings { border-left: 3px solid #F59E0B; }
    .property-card.is-clean { border-left: 3px solid #10B981; }

    .card-thumb {
      width: 56px; height: 42px; border-radius: 6px; object-fit: cover;
      flex-shrink: 0; background: #F3F4F6;
    }
    .card-body { flex: 1; min-width: 0; }
    .card-top { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
    .card-title {
      font-size: 0.8125rem; font-weight: 600; color: #111827;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1;
    }
    .card-title a { color: inherit; text-decoration: none; }
    .card-title a:hover { color: var(--ubikala-olive); }

    .card-meta {
      display: flex; align-items: center; gap: 12px; font-size: 0.6875rem; color: #6B7280; margin-bottom: 6px;
    }
    .card-meta span { display: inline-flex; align-items: center; gap: 3px; }
    .meta-sep { color: #D1D5DB; }

    .card-issues { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 6px; }
    .issue-tag {
      display: inline-block; padding: 2px 7px; border-radius: 4px;
      font-size: 0.625rem; font-weight: 500;
    }
    .issue-tag.error { background: #FEE2E2; color: #991B1B; }
    .issue-tag.warning { background: #FEF3C7; color: #92400E; }

    .card-dups {
      font-size: 0.6875rem; color: #6B7280; padding: 6px 0 2px;
      border-top: 1px dashed #E5E7EB; margin-top: 4px;
    }
    .card-dups strong { color: #4B5563; }
    .dup-score-tag {
      display: inline-block; background: #FEF3C7; color: #92400E;
      font-size: 0.5625rem; font-weight: 600; padding: 1px 5px; border-radius: 3px; margin-left: 4px;
    }

    .card-right {
      display: flex; flex-direction: column; align-items: flex-end; gap: 6px; flex-shrink: 0;
    }
    .score-badge {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 32px; height: 24px; border-radius: 5px; font-weight: 700; font-size: 0.6875rem;
    }
    .score-good { background: #D1FAE5; color: #065F46; }
    .score-ok { background: #FEF3C7; color: #92400E; }
    .score-bad { background: #FEE2E2; color: #991B1B; }

    .card-actions { display: flex; gap: 4px; }
    .btn-action {
      padding: 4px 10px; border: 1px solid #D1D5DB; border-radius: 5px;
      font-size: 0.625rem; font-weight: 600; cursor: pointer; background: #fff; transition: all 0.15s;
    }
    .btn-keep { color: #059669; border-color: #A7F3D0; }
    .btn-keep:hover { background: #D1FAE5; }
    .btn-remove { color: #DC2626; border-color: #FECACA; }
    .btn-remove:hover { background: #FEE2E2; }
    .btn-view { color: #6366F1; border-color: #C7D2FE; }
    .btn-view:hover { background: #EEF2FF; }

    /* Breakdown */
    .breakdown-section { margin-bottom: 32px; }
    .breakdown-section h3 { font-size: 0.875rem; font-weight: 600; color: #374151; margin: 0 0 12px; }
    .breakdown-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 8px; }
    .breakdown-item {
      display: flex; justify-content: space-between; align-items: center;
      padding: 8px 14px; background: #fff; border: 1px solid #E5E7EB; border-radius: 8px; font-size: 0.75rem;
    }
    .breakdown-item .code { color: #4B5563; font-weight: 500; }
    .breakdown-item .count {
      font-weight: 700; color: #111827; background: #F3F4F6;
      padding: 2px 8px; border-radius: 10px; font-size: 0.6875rem;
    }

    /* Modal */
    .modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 100;
      display: flex; align-items: center; justify-content: center;
    }
    .modal-box {
      background: #fff; border-radius: 12px; padding: 24px; width: 400px; max-width: 90vw;
    }
    .modal-box h3 { font-size: 1rem; font-weight: 600; color: #111827; margin: 0 0 8px; }
    .modal-box p { font-size: 0.8125rem; color: #4B5563; margin: 0 0 20px; }
    .modal-actions { display: flex; justify-content: flex-end; gap: 8px; }
    .btn-cancel {
      padding: 8px 16px; border: 1px solid #D1D5DB; border-radius: 6px;
      background: #fff; font-size: 0.8125rem; cursor: pointer; color: #374151;
    }
    .btn-danger {
      padding: 8px 16px; border: none; border-radius: 6px;
      background: #DC2626; color: #fff; font-size: 0.8125rem; font-weight: 600; cursor: pointer;
    }
    .btn-danger:hover { background: #B91C1C; }

    @media (max-width: 768px) {
      .page-header { flex-direction: column; gap: 12px; }
      .stats-row { grid-template-columns: repeat(2, 1fr); }
      .card-meta { flex-wrap: wrap; }
    }
  </style>

  <script>
    const ISSUE_LABELS: Record<string, string> = {
      TITULO_CORTO: 'Título corto',
      DESCRIPCION_CORTA: 'Desc. corta',
      FOTOS_INSUFICIENTES: 'Pocas fotos',
      PRECIO_FALTANTE: 'Sin precio',
      PRECIO_VENTA_BAJO: 'Precio bajo',
      PRECIO_VENTA_ALTO: 'Precio alto',
      PRECIO_RENTA_BAJO: 'Renta baja',
      PRECIO_RENTA_ALTO: 'Renta alta',
      UBICACION_INCOMPLETA: 'Sin ubicación',
      SIN_AGENTE: 'Sin agente',
      AGENTE_SIN_CONTACTO: 'Sin contacto',
      SIN_IMAGEN_PRINCIPAL: 'Sin imagen',
      POSIBLE_DUPLICADO: 'Duplicado',
    };

    interface Issue { code: string; message: string; severity: 'error' | 'warning'; }
    interface Duplicate { id: string; titulo: string; score: number; }
    interface Result {
      id: string; titulo: string; slug: string; imagen: string | null;
      tipo: string; operacion: string; precio: number | null; moneda: string;
      ciudad: string | null; sector: string | null;
      agente_nombre: string | null; score: number; issues: Issue[]; duplicates: Duplicate[];
    }
    interface AuditData {
      totalProperties: number; passing: number; failing: number; withWarnings: number;
      issueBreakdown: Record<string, number>; results: Result[];
    }

    let auditData: AuditData | null = null;

    const btn = document.getElementById('run-audit') as HTMLButtonElement;
    const statsRow = document.getElementById('stats-row')!;
    const filtersBar = document.getElementById('filters-bar')!;
    const loadingState = document.getElementById('loading-state')!;
    const emptyState = document.getElementById('empty-state')!;
    const resultsContainer = document.getElementById('results-container')!;
    const breakdownSection = document.getElementById('breakdown-section')!;
    const breakdownGrid = document.getElementById('breakdown-grid')!;
    const filterSeverity = document.getElementById('filter-severity') as HTMLSelectElement;
    const filterIssue = document.getElementById('filter-issue') as HTMLSelectElement;
    const resultsCount = document.getElementById('results-count')!;
    const modalOverlay = document.getElementById('modal-overlay')!;
    const modalTitle = document.getElementById('modal-title')!;
    const modalMessage = document.getElementById('modal-message')!;
    const modalCancel = document.getElementById('modal-cancel')!;
    const modalConfirm = document.getElementById('modal-confirm')!;

    let pendingAction: { propertyId: string; cardEl: HTMLElement } | null = null;

    btn.addEventListener('click', runAudit);
    filterSeverity.addEventListener('change', renderResults);
    filterIssue.addEventListener('change', renderResults);

    modalCancel.addEventListener('click', () => { modalOverlay.style.display = 'none'; pendingAction = null; });
    modalConfirm.addEventListener('click', async () => {
      if (!pendingAction) return;
      modalConfirm.textContent = 'Eliminando...';
      modalConfirm.setAttribute('disabled', 'true');
      try {
        const res = await fetch('/api/admin/quality-audit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ propertyId: pendingAction.propertyId, action: 'remove' }),
        });
        if (res.ok) {
          pendingAction.cardEl.classList.add('removed');
          pendingAction.cardEl.innerHTML = '<span style="font-size:0.75rem;color:#9CA3AF;padding:8px">Eliminada del índice</span>';
        }
      } catch {}
      modalOverlay.style.display = 'none';
      modalConfirm.textContent = 'Confirmar';
      modalConfirm.removeAttribute('disabled');
      pendingAction = null;
    });

    async function runAudit() {
      btn.disabled = true;
      btn.textContent = 'Analizando...';
      emptyState.style.display = 'none';
      loadingState.style.display = 'block';
      resultsContainer.style.display = 'none';
      statsRow.style.display = 'none';
      filtersBar.style.display = 'none';
      breakdownSection.style.display = 'none';

      try {
        const refresh = auditData ? 'true' : 'false';
        const res = await fetch(`/api/admin/quality-audit?refresh=${refresh}`);
        if (!res.ok) throw new Error();
        auditData = await res.json();
        renderAll();
      } catch {
        loadingState.innerHTML = '<p style="color:#EF4444">Error al ejecutar auditoría.</p>';
      } finally {
        btn.disabled = false;
        btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="btn-icon"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg> Re-ejecutar`;
      }
    }

    function renderAll() {
      if (!auditData) return;
      loadingState.style.display = 'none';

      document.getElementById('stat-total')!.textContent = String(auditData.totalProperties);
      document.getElementById('stat-passing')!.textContent = String(auditData.passing);
      document.getElementById('stat-failing')!.textContent = String(auditData.failing);
      document.getElementById('stat-warnings')!.textContent = String(auditData.withWarnings);
      statsRow.style.display = 'grid';

      filterIssue.innerHTML = '<option value="all">Todos los problemas</option>';
      for (const [code, count] of Object.entries(auditData.issueBreakdown).sort((a, b) => b[1] - a[1])) {
        const opt = document.createElement('option');
        opt.value = code;
        opt.textContent = `${ISSUE_LABELS[code] || code} (${count})`;
        filterIssue.appendChild(opt);
      }
      filtersBar.style.display = 'flex';

      breakdownGrid.innerHTML = '';
      for (const [code, count] of Object.entries(auditData.issueBreakdown).sort((a, b) => b[1] - a[1])) {
        breakdownGrid.innerHTML += `<div class="breakdown-item"><span class="code">${ISSUE_LABELS[code] || code}</span><span class="count">${count}</span></div>`;
      }
      breakdownSection.style.display = 'block';

      renderResults();
    }

    function renderResults() {
      if (!auditData) return;

      const severity = filterSeverity.value;
      const issue = filterIssue.value;
      let filtered = auditData.results;

      if (severity === 'errors') filtered = filtered.filter(r => r.issues.some(i => i.severity === 'error'));
      else if (severity === 'warnings') filtered = filtered.filter(r => r.issues.length > 0 && !r.issues.some(i => i.severity === 'error'));
      else if (severity === 'clean') filtered = filtered.filter(r => r.issues.length === 0);
      else if (severity === 'duplicates') filtered = filtered.filter(r => r.duplicates.length > 0);
      if (issue !== 'all') filtered = filtered.filter(r => r.issues.some(i => i.code === issue));

      resultsCount.textContent = `${filtered.length} de ${auditData.results.length} propiedades`;
      resultsContainer.innerHTML = '';

      for (const r of filtered) {
        const scoreClass = r.score >= 80 ? 'score-good' : r.score >= 50 ? 'score-ok' : 'score-bad';
        const cardClass = r.issues.some(i => i.severity === 'error') ? 'has-errors'
          : r.issues.length > 0 ? 'has-warnings' : 'is-clean';
        const precio = r.precio ? `${r.moneda} ${r.precio.toLocaleString()}` : '—';
        const img = r.imagen || '/images/property-placeholder.svg';

        const card = document.createElement('div');
        card.className = `property-card ${cardClass}`;
        card.dataset.id = r.id;

        let issuesHtml = '';
        for (const iss of r.issues) {
          const cls = iss.severity === 'error' ? 'error' : 'warning';
          issuesHtml += `<span class="issue-tag ${cls}" title="${esc(iss.message)}">${ISSUE_LABELS[iss.code] || iss.code}</span>`;
        }

        let dupsHtml = '';
        if (r.duplicates.length > 0) {
          dupsHtml = '<div class="card-dups"><strong>Duplicados:</strong> ';
          dupsHtml += r.duplicates.map(d => `${esc(d.titulo)} <span class="dup-score-tag">${d.score}%</span>`).join(', ');
          dupsHtml += '</div>';
        }

        card.innerHTML = `
          <img src="${img}" class="card-thumb" alt="" loading="lazy" />
          <div class="card-body">
            <div class="card-top">
              <span class="card-title"><a href="/propiedad/${r.slug}" target="_blank">${esc(r.titulo)}</a></span>
              <span class="score-badge ${scoreClass}">${r.score}</span>
            </div>
            <div class="card-meta">
              <span>${r.tipo} · ${r.operacion}</span>
              <span class="meta-sep">|</span>
              <span>${precio}</span>
              <span class="meta-sep">|</span>
              <span>${r.ciudad || 'Sin ciudad'}${r.sector ? ', ' + r.sector : ''}</span>
              <span class="meta-sep">|</span>
              <span>${r.agente_nombre || '<b style="color:#EF4444">Sin agente</b>'}</span>
            </div>
            ${issuesHtml ? `<div class="card-issues">${issuesHtml}</div>` : ''}
            ${dupsHtml}
          </div>
          <div class="card-right">
            <div class="card-actions">
              <button class="btn-action btn-view" data-action="view" data-slug="${r.slug}">Ver</button>
              <button class="btn-action btn-keep" data-action="keep" data-id="${r.id}">OK</button>
              <button class="btn-action btn-remove" data-action="remove" data-id="${r.id}" data-title="${esc(r.titulo)}">Eliminar</button>
            </div>
          </div>
        `;

        // Event delegation for buttons
        card.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          const action = target.dataset.action;
          if (!action) return;
          e.stopPropagation();

          if (action === 'view') {
            window.open(`/propiedad/${target.dataset.slug}`, '_blank');
          } else if (action === 'keep') {
            card.style.display = 'none';
          } else if (action === 'remove') {
            pendingAction = { propertyId: target.dataset.id!, cardEl: card };
            modalTitle.textContent = 'Eliminar propiedad del índice';
            modalMessage.textContent = `¿Eliminar "${target.dataset.title}" del índice de Ubikala? La propiedad dejará de aparecer en el sitio.`;
            modalOverlay.style.display = 'flex';
          }
        });

        resultsContainer.appendChild(card);
      }

      resultsContainer.style.display = 'block';
    }

    function esc(text: string): string {
      const d = document.createElement('div');
      d.textContent = text;
      return d.innerHTML;
    }
  </script>
</AdminLayout>
